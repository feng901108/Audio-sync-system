# === 排除不需要进镜像的内容 ===

# 数据和上传的音频（运行时挂载 volume）
data/
data/audio/*
!data/audio/.gitkeep
data/app.db
data/app.db-*

# git 历史（构建时不需要）
.git/
.gitignore

# 本机开发残留
.chrome-data/
.vscode/
.idea/

# 系统文件
.DS_Store
Thumbs.db

# 日志
*.log
data/server.log

# 文档（不进镜像；保留在工作区）
README.md
README-DOCKER.md
DEPLOY-NEEDS.md
CLAUDE.md

# Node 依赖（当前零依赖；未来加的话确保 .dockerignore 在前）
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 测试文件（未来加）
test/
tests/
*.test.mjs
*.spec.mjs

# 临时测试脚本（带点的隐藏文件，已存在过）
.zone-*.mjs
.zombie-test.mjs
.delay-test.mjs
.ip-test.mjs
.sync-test.mjs
.err-test.mjs
.ws-*.mjs
.test.mp3
.fake.mp3
