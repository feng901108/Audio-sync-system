# 本地开发 override（不参与生产部署）
#
# 用法：
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   docker compose up
#
# 这个文件让本机开发时：
#   1. 直接 mount 源码（修改即时生效，配合 node --watch）
#   2. 暴露 9229 端口给 Node Inspector（VSCode 调试）
#   3. 跑 dev 模式

services:
  juguang:
    # 挂源码进去（只读，避免容器内误删）
    volumes:
      - ./server:/app/server:ro
      - ./web:/app/web:ro
      - ./data-dev:/app/data
    environment:
      NODE_ENV: development
    # 覆盖默认 command：开发模式用 --watch 热重启
    command: ["node", "--watch", "server/index.mjs"]
    # 不挂 restart（开发环境不需要自动重启）
    restart: "no"
