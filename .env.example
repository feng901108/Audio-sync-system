# 复制为 .env 后填值。.env 不进 git。
# docker compose 会自动加载 .env 中的变量（只识别大写 + JUGUANG_/TZ）。

# === 服务（docker compose 用） ===
# 容器内固定 3000，这里改的是 NAS 上对外的端口
JUGUANG_PORT=3000
# 时区
TZ=Asia/Shanghai

# === 本机 → NAS 部署（scripts/deploy.sh 用） ===
# WebDAV 挂载点（Windows: Z: / macOS: /Volumes/xxx / Linux: /mnt/xxx）
NAS_WEBDAV=Z:/juguang
# 容器名（NAS 上 docker ps 第一列），仅做提示用
NAS_CONTAINER=juguang
# 默认 commit 前缀（feat/fix/refactor/chore/docs）
COMMIT_PREFIX=feat
